<!doctype html>
<html lang="en" data-theme="emerald">
<%- include('./src/partials/head.ejs', { title: 'Contact us: Portfolio Tracker', description: 'Get in touch with the Portfolio Tracker team.', slug: '/contact' }) %>

<body class="bg-white pt-25 font-sans text-gray-900 antialiased">
  <!-- Schema markup for ContactPage -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "mainEntity": {
        "@type": "Organization",
        "name": "Portfolio Tracker",
        "url": "https://portfoliotrackergooglesheets.com",
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "url": "https://portfoliotrackergooglesheets.com/contact"
        }
      }
    }
  </script>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NGRM269Z" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <!-- Header -->
  <%- include('./src/partials/header.ejs') %>
  <main>
    <section>
      <div class="container mx-auto px-4 py-4 md:px-6 md:py-16 max-w-2xl">
        <h1 class="font-display text-2xl md:text-5xl mb-3">
          Contact Us
        </h1>
        <p class="mb-12">If you have any questions or feedback regarding our portfolio tracker Add-on, reach out using the form below.</p>
        <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSdyWFlTCnA3AXK3EGhWSMprvMSImYx51FI9xUGU1ljhnhFpSg/viewform?embedded=true" width="100%" height="1000" frameborder="0" marginheight="0" marginwidth="0" title="Contact Form for Portfolio Tracker Support">Loading…</iframe>
      </div>
    </section>
  </main>
  <!-- Footer -->
  <%- include('./src/partials/footer.ejs') %>
</body>

</html>