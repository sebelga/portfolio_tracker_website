<!doctype html>
<html lang="en" data-theme="emerald">
<%- include('./src/partials/head.ejs', { title: 'Portfolio Tracker for Google Sheets - Track Investments Easily', description: 'Effortlessly track stocks, crypto, and options in Google Sheets. Manage taxes, visualize performance, and automate snapshots with our add-on.' }) %>

<body>
  <!-- Schema markup for SoftwareApplication -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Portfolio Tracker",
      "description": "Track your stock, crypto, and options investments in Google Sheets with automated trade matching, tax calculations, and performance dashboards.",
      "url": "https://portfoliotrackergooglesheets.com",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    }
  </script>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NGRM269Z" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <!-- Header -->
  <%- include('./src/partials/header.ejs') %>
  <main>
    <!-- Hero Section -->
    <section class="hero min-h-[75vh] md:mt-[90px] pb-8">
      <div class="container flex items-center flex-col mx-auto gap-10 px-4 md:px-16 lg:flex-row">
        <div class="mt-8 flex-1">
          <img src="/img/hero-image.jpg" class="w-full max-w-sm sm:max-w-md lg:max-w-2xl" alt="Portfolio Tracker interface showing investment tracking features in Google Sheets" />
        </div>
        <div class="flex-1">
          <h1 class="text-4xl font-bold mb-4">Portfolio Tracker in Google Sheets™ <span class="badge badge-warning">Beta</span></h1>
          <p class="text-xl mb-8">Track your stock, crypto, and options investments in Google Sheets™.<br>Follow your trades, manage your taxes, and visualize your performance effortlessly in a single spreadsheet.</p>
          <p class="text-lg text-gray-600 mb-4">We're in Beta! <a href="/contact" class="link link-primary text-green-600 hover:text-green-800"> Contact us</a> if you'd like to try it out first.</p>
        </div>
      </div>
    </section>

    <!-- Problem & Solution Section -->
    <section class="py-20 px-4 bg-gray-100">
      <div class="container mx-auto md:px-16 flex flex-col gap-8">
        <div class="mb-12">
          <h2 class="text-4xl font-bold mb-4">Portfolio Tracker Add-on for Google Sheets</h2>
          <p class="text-xl mb-4">Our Google Sheets™ add-on and provided template sheet transform your transaction ledger into smart trades. It handles FIFO/LIFO matching, computes realized/unrealized P&L, tax calculation, live prices for stock, crypto and options contracts, and generates a dashboard for clear insights.</p>
          <p class="text-xl">Seamlessly integrate with Google Sheets™ App Script triggers for daily automated snapshots of your assets portfolio.</p>
        </div>
        <div>
          <img src="/img/portfolio_tracker.jpg" class="w-full" alt="Overview of Portfolio Tracker add-on dashboard with charts and data visualization" />
        </div>
      </div>
    </section>

    <!-- Key Features & Benefits Section -->
    <section class="py-20 px-4 bg-white">
      <div class="container mx-auto md:px-16">
        <h2 class="text-4xl font-bold text-center mb-12">Key Features for Portfolio Tracking in Google Sheets</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="card bg-gray-100 shadow-lg p-6 rounded-lg">
            <h3 class="text-2xl font-semibold mb-4">Smart Trade Matching</h3>
            <p class="text-lg">Automatically creates open/closed trades from transactions using FIFO or LIFO. Track realized profits and open positions effortlessly.</p>
          </div>
          <div class="card bg-gray-100 shadow-lg p-6 rounded-lg">
            <h3 class="text-2xl font-semibold mb-4">Tax Calculation</h3>
            <p class="text-lg">Set custom rates for short/long-term gains across stocks, crypto, and options. Accurate computations for better financial planning.</p>
          </div>
          <div class="card bg-gray-100 shadow-lg p-6 rounded-lg">
            <h3 class="text-2xl font-semibold mb-4">Multi-Currency Support</h3>
            <p class="text-lg">Set a base currency for your portfolio and trade assets in any currencies. Your ROI, P&L and Tax calculations will account for exchange rate fluctuations.<br>Real-world ROI reflecting currency impacts!</p>
          </div>
          <div class="card bg-gray-100 shadow-lg p-6 rounded-lg">
            <h3 class="text-2xl font-semibold mb-4">Stock splits</h3>
            <p class="text-lg">Automatically adjusts your equity shares and options contracts holdings and cost basis for stock splits, ensuring accurate tracking of your investments.</p>
          </div>
          <div class="card bg-gray-100 shadow-lg p-6 rounded-lg">
            <h3 class="text-2xl font-semibold mb-4">Transaction Categories</h3>
            <p class="text-lg">Group trades (e.g., trading vs. HODL) for segmented analysis in separate sheets.</p>
          </div>
          <div class="card bg-gray-100 shadow-lg p-6 rounded-lg">
            <h3 class="text-2xl font-semibold mb-4">Live prices</h3>
            <p class="text-lg">Get real-time market prices for stocks, crypto<sup>*</sup>, and options<sup>**</sup> directly in your spreadsheet.</p>
          </div>
          <div class="card bg-gray-100 shadow-lg p-6 rounded-lg">
            <h3 class="text-2xl font-semibold mb-4">Asset Snapshots</h3>
            <p class="text-lg">Create daily snapshots of your portfolio values using Google Sheets™ Triggers for historical tracking.</p>
          </div>
          <div class="card bg-gray-100 shadow-lg p-6 rounded-lg">
            <h3 class="text-2xl font-semibold mb-4">Utility Functions</h3>
            <p class="text-lg">Cell formulas for currency conversions, date-specific rates, and more to enhance your sheets.</p>
          </div>
        </div>
        <div class="text-sm text-gray-700 mt-12">
          <p><sup>*</sup>Requires a <a href="https://coinmarketcap.com/api/" target="_blank" rel="noopener noreferrer" class="link link-primary text-green-600 hover:text-green-800">CoinMarketCap API key</a>.</p>
          <p><sup>**</sup>Requires a <a href="https://massive.com/options" target="_blank" rel="noopener noreferrer" class="link link-primary text-green-600 hover:text-green-800">Massive.com "Options Starter" subscription</a>.</p>
        </div>
      </div>
    </section>

    <!-- Visual Appeal & User Experience Section -->
    <section class="py-20 md:py-30 px-4 bg-gray-100">
      <div class="container mx-auto">
        <h2 class="text-4xl font-bold text-center mb-12">Portfolio Tracker Screenshots</h2>

        <div id="gallery" class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8">
          <div class="shadow-lg rounded-lg">
            <a class="h-full w-full overflow-hidden" href="/img/screenshots/dashboard.jpg" target="_blank" data-pswp-width="1800" data-pswp-height="1000">
              <img class="gallery-thumb h-auto w-full rounded-lg object-cover" src="/img/screenshots/524/dashboard.jpg" alt="Portfolio Tracker dashboard displaying performance charts and investment metrics in Google Sheets" loading="lazy" />
            </a>
          </div>
          <div class="shadow-lg rounded-lg">
            <a class="h-full w-full overflow-hidden" href="/img/screenshots/summary.jpg" target="_blank" data-pswp-width="1800" data-pswp-height="1000">
              <img class="gallery-thumb h-auto w-full rounded-lg object-cover" src="/img/screenshots/524/summary.jpg" alt="Portfolio Tracker summary view showing open positions and trade details in Google Sheets" loading="lazy" />
            </a>
          </div>
          <div class="shadow-lg rounded-lg">
            <a class="h-full w-full overflow-hidden" href="/img/screenshots/transactions.jpg" target="_blank" data-pswp-width="1800" data-pswp-height="1000">
              <img class="gallery-thumb h-auto w-full rounded-lg object-cover" src="/img/screenshots/524/transactions.jpg" alt="Portfolio Tracker transactions sheet with buy and sell entries for stocks, options and crypto in Google Sheets" loading="lazy" />
            </a>
          </div>
          <div class="hidden">
            <a class="h-full w-full overflow-hidden" href="/img/screenshots/multi-currencies.jpg" target="_blank" data-pswp-width="1800" data-pswp-height="1000">
              <img class="gallery-thumb h-auto w-full rounded-lg object-cover" src="/img/screenshots/524/multi-currencies.jpg" alt="Portfolio Tracker multi-currency view showing exchange rates and international investments in Google Sheets" loading="lazy" />
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action Section -->
    <section id="cta" class="py-20 px-4 bg-gray-800 text-white text-center">
      <div class="container mx-auto">
        <h2 class="text-4xl font-bold mb-4">Join Our Beta for Portfolio Tracking</h2>
        <p class="text-xl mb-8">We're in beta release. Contact us to get early access and try it out.</p>
        <a href="/contact" class="btn btn-primary btn-lg">Contact Us</a>
      </div>
    </section>
  </main>
  <!-- Footer -->
  <%- include('./src/partials/footer.ejs') %>
</body>

</html>