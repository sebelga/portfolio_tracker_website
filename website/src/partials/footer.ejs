<footer class="footer footer-vertical sm:footer-horizontal bg-base-200 text-base-content p-10">
  <nav>
    <h6 class="footer-title">Product</h6>
    <a href="/pricing" class="link link-hover">Pricing</a>
    <a href="/docs" class="link link-hover">Documentation</a>
    <a href="/about" class="link link-hover">About</a>
  </nav>
  <nav>
    <h6 class="footer-title">Support</h6>
    <a href="/contact" class="link link-hover">Contact</a>
    <a href="/docs/faq" class="link link-hover">FAQ</a>
    <button onclick="footer_newsletter_modal.showModal()" class="link link-hover text-left">Subscribe to product updates</button>
  </nav>
  <nav>
    <h6 class="footer-title">Legal</h6>
    <a href="/terms-and-services" class="link link-hover">Terms of service</a>
    <a href="/privacy-policy" class="link link-hover">Privacy policy</a>
  </nav>
  <nav>
    <h6 class="footer-title">Template</h6>
    <span class="text-xs opacity-60">Latest version: v<%= templateVersion %></span>
    <button onclick="request_template_modal.showModal()" class="link link-hover text-left">Get your copy</button>
  </nav>
</footer>

<footer class="footer footer-horizontal bg-base-200 text-base-content border-base-300 border-t px-10 py-4">
  <aside class="grid-flow-col items-center">
    <p>&copy; <%= new Date().getFullYear() %> TradeGist Add-on. All rights reserved.</p>
  </aside>
